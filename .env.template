# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_ANALYSIS_CHANNEL_ID=0
DISCORD_ALERTS_CHANNEL_ID=0
DISCORD_COMMANDS_CHANNEL_ID=0

# Claude API (for AI commentary)
CLAUDE_API_KEY=your_claude_api_key_here
# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Tastytrade (primary data source — free with brokerage account)
# Create an OAuth app at developer.tastytrade.com, then generate a refresh token
TASTYTRADE_CLIENT_SECRET=your_tastytrade_client_secret
TASTYTRADE_REFRESH_TOKEN=your_tastytrade_refresh_token
# Set to "true" for sandbox/certification environment
TASTYTRADE_SANDBOX=false

# Tradier Sandbox (fallback data source)
TRADIER_TOKEN=your_tradier_sandbox_token_here

# TradingView Webhook
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_webhook_secret_here
DISCORD_WEBHOOK_ALERTS_CHANNEL_ID=0

# CheddarFlow
DISCORD_CHEDDARFLOW_CHANNEL_ID=0
DISCORD_CHEDDARFLOW_OUTPUT_CHANNEL_ID=0
CHEDDARFLOW_MIN_PREMIUM=50000

# ORATS (historical data source — Phase 2)
ORATS_API_KEY=your_orats_api_key_here

# Strategy system (Phase 2)
STRATEGY_DIR=strategies

# Historical data storage (Phase 2)
HISTORICAL_DATA_DIR=data/historical

# Journal system (Phase 2-3)
# Discord channel for journal summaries (daily, weekly, notes)
DISCORD_JOURNAL_CHANNEL_ID=0
# Day of month for auto monthly report (1-28)
MONTHLY_REPORT_DAY=1
